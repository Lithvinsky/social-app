# API origin (no trailing slash). Prefer VITE_API_URL; VITE_API_BASE is an alias.
# Leave unset in local dev to use the Vite proxy (/api → backend on port 5050).
# VITE_API_URL=https://your-api.onrender.com
#
# Vercel / production static hosts: set VITE_API_URL (and usually VITE_SOCKET_URL) in the dashboard.
#
# Optional: dev-only proxy target when backend is not on 127.0.0.1:5050
# VITE_PROXY_TARGET=http://127.0.0.1:5050
#
# Socket.IO usually matches the API host; override if needed:
# VITE_SOCKET_URL=https://your-api.onrender.com
#
# On the API, set CLIENT_ORIGIN=https://your-app.vercel.app and REFRESH_COOKIE_SAMESITE=none
# so CORS + refresh cookies work across origins.
