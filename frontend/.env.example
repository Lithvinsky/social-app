# FIXED: updated API base URL to correct Render backend
# Local dev/prod: set VITE_API_URL to your API origin (no trailing slash).
# VITE_API_URL="http://localhost:5050"

# Socket.io (must be a URL the browser can reach; same as API in dev):
VITE_SOCKET_URL=http://localhost:5050

# --- Production (Vercel, Netlify, etc.): set BOTH in the host’s Environment Variables
# and redeploy. They are baked in at *build* time (Vite).
# No trailing slash. Use your real API origin (e.g. Render, Railway, Fly):
# VITE_API_URL="https://your-api.onrender.com"
# VITE_SOCKET_URL=https://your-api.onrender.com
#
# On the API, set CLIENT_ORIGIN=https://your-app.vercel.app and REFRESH_COOKIE_SAMESITE=none
# so CORS + refresh cookies work across origins.
