NODE_ENV=development
PORT=5050
MONGO_URI=mongodb://127.0.0.1:27017/social-app

JWT_ACCESS_SECRET=change-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-refresh-secret-different-min-32
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

CLIENT_ORIGIN=http://localhost:5174

# When frontend and API are on different origins (e.g. Vercel + Render), set:
# REFRESH_COOKIE_SAMESITE=none
# (HTTPS required; browser will send refresh cookie on cross-site credentialed requests.)

# Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
